rules_version = '2';

service cloud.firestore {
    match /databases/{database}/documents {

        // Règle par défaut : tout est interdit
        match /{document=**} {
            allow read, write: if false;
        }

        // Tâches privées : seul le propriétaire peut lire/écrire
        match /users/{userId}/tasks/{taskId} {
            allow read, write: if request.auth != null && request.auth.uid == userId;
        }

        // Profil utilisateur (pour la recherche par email)
        match /users/{userId} {
            allow read: if request.auth != null;
            allow write: if request.auth != null && request.auth.uid == userId;
        }
        
        // Listes partagées
        match /sharedLists/{listId} {
            // Lecture : seuls les membres peuvent lire
            allow read: if request.auth != null
                        && request.auth.uid in resource.data.members;

            // Création : tout utilisateur connecté peut créer une liste
            allow create: if request.auth != null
                          && request.auth.uid == request.resource.data.ownerId
                          && request.auth.uid in request.resource.data.members;

            // Mise à jour : seul le owner peut modifier (ajouter/retirer des membres)
            allow update: if request.auth != null
                          && request.auth.uid == resource.data.ownerId;

            // Suppression : seul le owner peut supprimer
            allow delete: if request.auth != null
                          && request.auth.uid == resource.data.ownerId;
                          
            // Tâches d'une liste partagée : les membres peuvent lire/écrire
            match /tasks/{taskId} {
                allow read, write: if request.auth != null
                                   && request.auth.uid in get(/databases/$(database)/documents/sharedLists/$(listId)).data.members;
            }
        }
    }
}
